# Copy this file to .env and fill in your API keys.
# .env is gitignored so your keys stay out of the repo.

# Required
OPENAI_API_KEY=your-openai-key-here

# Optional: nutrition lookup via USDA FoodData Central (free)
# Get key at: https://fdc.nal.usda.gov/api-guide.html
USDA_API_KEY=your-usda-key-here

# Optional: nearby restaurant search via Google Maps Places API (free tier)
# Steps: console.cloud.google.com → create project → enable "Places API (New)" → create API key
GOOGLE_MAPS_API_KEY=your-google-maps-key-here

# Optional: Logfire monitoring dashboard (free tier)
# Sign up at https://logfire.pydantic.dev and create a project to get a token
LOGFIRE_TOKEN=your-logfire-token-here
