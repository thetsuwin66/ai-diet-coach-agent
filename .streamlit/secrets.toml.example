# Copy this to .streamlit/secrets.toml for local use,
# OR paste these key=value pairs into the Streamlit Cloud secrets dashboard.
# Never commit secrets.toml to git.

OPENAI_API_KEY = "your-openai-key-here"

# Optional
USDA_API_KEY = "your-usda-key-here"
GOOGLE_MAPS_API_KEY = "your-google-maps-key-here"
